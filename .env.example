# --- AI Providers ---
# Gemini (Google): https://ai.google.dev/
VITE_GEMINI_ENABLED=true
VITE_GEMINI_API_KEY="your-gemini-api-key"

# Mistral: https://console.mistral.ai/
VITE_MISTRAL_ENABLED=true
VITE_MISTRAL_API_KEY="your-mistral-api-key"
VITE_MISTRAL_MODEL_NAME="mistral-small-latest"

# Приоритетный провайдер: gemini или mistral
VITE_LLM_PRIMARY="mistral"

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
