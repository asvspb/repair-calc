# --- AI Providers ---
# Gemini (Google): https://ai.google.dev/
VITE_GEMINI_ENABLED=true
VITE_GEMINI_API_KEY="your-gemini-api-key"

# Mistral: https://console.mistral.ai/
VITE_MISTRAL_ENABLED=true
VITE_MISTRAL_API_KEY="your-mistral-api-key"
VITE_MISTRAL_MODEL_NAME="mistral-small-latest"

# Приоритетный провайдер: gemini или mistral
VITE_LLM_PRIMARY="mistral"

# --- MySQL Database ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=repair_calc

# --- Client API ---
VITE_API_URL=http://localhost:3993

# --- Server ---
SERVER_PORT=3994
APP_URL=http://localhost:3993

# --- JWT ---
JWT_SECRET=your-super-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production

# --- UPDATE_SERVICE: Scheduler ---
UPDATE_SCHEDULER_ENABLED=true
UPDATE_CRON="0 3 * * *"
UPDATE_TIMEZONE="Europe/Moscow"
UPDATE_MAX_CONCURRENT_JOBS=3

# --- UPDATE_SERVICE: Retry ---
UPDATE_RETRY_ON_FAILURE=true
UPDATE_RETRY_DELAY_MS=300000
UPDATE_MAX_RETRIES=3

# --- UPDATE_SERVICE: Cache (Redis) ---
UPDATE_CACHE_ENABLED=true
UPDATE_CACHE_PROVIDER=redis           # 'redis' | 'memory'
UPDATE_CACHE_TTL_MS=3600000           # 1 час
UPDATE_CACHE_HOST=localhost
UPDATE_CACHE_PORT=6379

# --- UPDATE_SERVICE: Concurrency ---
UPDATE_BATCH_SIZE=10
UPDATE_CONCURRENT_REQUESTS=5
UPDATE_REQUEST_DELAY_MS=500

# --- UPDATE_SERVICE: Anomaly Detection ---
UPDATE_ANOMALY_DETECTION_ENABLED=true
UPDATE_ANOMALY_THRESHOLD_PERCENT=100   # 100% изменение цены
UPDATE_ANOMALY_REVIEW_REQUIRED=true

# --- UPDATE_SERVICE: Circuit Breaker ---
UPDATE_CIRCUIT_BREAKER_THRESHOLD=5
UPDATE_CIRCUIT_BREAKER_RESET_TIMEOUT_MS=600000  # 10 минут

# --- UPDATE_SERVICE: Rate Limits ---
UPDATE_GEMINI_RATE_LIMIT_PER_MINUTE=60
UPDATE_GEMINI_RATE_LIMIT_PER_DAY=10000
UPDATE_MISTRAL_RATE_LIMIT_PER_MINUTE=100
UPDATE_MISTRAL_RATE_LIMIT_PER_DAY=50000

# --- UPDATE_SERVICE: Web Scrapers ---
UPDATE_LEMANA_ENABLED=true
UPDATE_LEMANA_BASE_URL="https://volgograd.lemanapro.ru/catalogue/"
UPDATE_LEMANA_MAX_CATEGORIES=3
UPDATE_LEMANA_MAX_PAGES=3
UPDATE_LEMANA_DELAY_MS=1000

UPDATE_BAZAVIT_ENABLED=true
UPDATE_BAZAVIT_BASE_URL="https://bazavit.ru/catalog/"
UPDATE_BAZAVIT_MAX_CATEGORIES=3
UPDATE_BAZAVIT_MAX_PAGES=3
UPDATE_BAZAVIT_DELAY_MS=1000

# --- UPDATE_SERVICE: A/B Testing ---
UPDATE_AB_TEST_ENABLED=false
UPDATE_AB_TEST_GEMINI_WEIGHT=50        # Процент запросов к Gemini

# --- UPDATE_SERVICE: Webhooks ---
UPDATE_WEBHOOKS_ENABLED=false
UPDATE_WEBHOOK_RETRY_COUNT=3
UPDATE_WEBHOOK_TIMEOUT_MS=5000

# --- Playwright (для web scrapers) ---
# Устанавливается автоматически при npm install playwright
# Для работы в Docker/CI может потребоваться: npx playwright install-deps
